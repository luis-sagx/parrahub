# PostgreSQL
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpassword
POSTGRES_DB=chatdb
DATABASE_URL=postgresql://chatuser:chatpassword@postgres:5432/chatdb

# MongoDB
MONGO_INITDB_ROOT_USERNAME=chatuser
MONGO_INITDB_ROOT_PASSWORD=chatpassword
MONGODB_URI=mongodb://chatuser:chatpassword@mongodb:27017/chatdb?authSource=admin

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chat-files

# Backend
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin1234!
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Frontend / Nginx
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
